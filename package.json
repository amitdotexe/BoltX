{
  "name": "boltx",
  "displayName": "BoltX",
  "description": "AI-powered project scaffolding with diff review",
  "publisher": "amitmallick837",
  "version": "1.0.3",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/amitdotexe/BoltX"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "bin": {
    "boltx": "./boltx-cli.js"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "boltx.run",
        "title": "BoltX: Run"
      },
      {
        "command": "boltx.setApiKey",
        "title": "BoltX: Set API Key"
      },
      {
        "command": "boltx.setProvider",
        "title": "BoltX: Set AI Provider"
      }
    ]
  }
}
